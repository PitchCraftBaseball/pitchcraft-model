#!/usr/bin/bash

set -euo pipefail

repo_root="$(cd "$(dirname "$0")" && pwd)"
cd "$repo_root"

if [ ! -d "venv" ]; then
    python3 -m venv venv
fi
source venv/bin/activate
pip install -r requirements.txt

# bootstrap parquet files to docker image 
python -m model_shared.setup

uvicorn model_server.src.api:app --host 0.0.0.0 --port 8000


